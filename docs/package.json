{
	"name": "docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm build:content && vite dev",
		"build": "pnpm build:content && wrangler types && vite build && pagefind --site .svelte-kit/cloudflare",
		"build:content": "velite",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "pnpm build:content && wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@iconify-json/heroicons": "^1.2.3",
		"@iconify/svelte": "^5.2.2",
		"@inlang/paraglide-js": "^2.18.2",
		"@internationalized/date": "^3.12.2",
		"@playwright/test": "^1.60.0",
		"@shikijs/langs": "^3.23.0",
		"@shikijs/themes": "^3.23.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsx": "^0.0.7",
		"pagefind": "^1.5.2",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rehype-slug": "^6.0.0",
		"remark-cjk-friendly": "^2.3.1",
		"remark-directive": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^3.23.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"unist-util-visit": "^5.1.0",
		"velite": "^0.4.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.97.0"
	},
	"dependencies": {
		"mode-watcher": "^1.1.0"
	}
}
